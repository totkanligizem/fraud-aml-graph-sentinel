.DS_Store
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.venv/
venv/

# Never commit downloaded raw datasets
data/raw/**
!data/raw/**/.gitkeep

# Generated curated outputs
data/curated/**
!data/curated/**/.gitkeep

# Generated warehouse files
data/warehouse/**
!data/warehouse/**/.gitkeep

# Generated synthetic sample outputs
data/sample/transaction_event/**
!data/sample/transaction_event/.gitkeep
data/sample/warehouse/**
!data/sample/warehouse/.gitkeep

# Generated run artifacts (models, summaries, temp exports)
artifacts/**
!artifacts/**/.gitkeep

# Local logs
*.log
tmp/

# Local secrets / env
.secrets/
api keys/
.env
.env.*
!.env.example
*.pem
*.p12
*.pfx
*.key
*service-account*.json
*credentials*.json

# Local operator screenshots / notes
gerekli ss ler/
